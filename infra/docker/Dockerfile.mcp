FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV DISPLAY=:99
ENV PYTHONUNBUFFERED=1
ENV PYTHONIOENCODING=utf-8
ENV PLAYWRIGHT_LAUNCH_OPTIONS='{"args": ["--no-sandbox", "--disable-setuid-sandbox", "--disable-dev-shm-usage"]}'

# 1. System Dependencies
RUN apt-get update && apt-get install -y \
    xvfb \
    fluxbox \
    x11-xserver-utils \
    x11-utils \
    scrot \
    libnss3 \
    libxss1 \
    libasound2 \
    libgl1 \
    libglib2.0-0 \
    curl \
    git \
    procps \
    x11vnc \
    dos2unix \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 2. Python Packages
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 3. Playwright Browsers & Deps
RUN playwright install chromium
RUN playwright install-deps chromium

# 4. Setup Entrypoint — dos2unix fixes Windows CRLF line endings
COPY infra/docker/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN dos2unix /usr/local/bin/entrypoint.sh && chmod +x /usr/local/bin/entrypoint.sh

# 5. Healthcheck
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD xdpyinfo -display $DISPLAY >/dev/null || exit 1

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
